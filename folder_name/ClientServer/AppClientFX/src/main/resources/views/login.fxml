<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="app.client.gui.LoginController"
            prefHeight="400.0" prefWidth="400.0">

    <VBox alignment="CENTER" spacing="10.0"
          AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">

        <Label style="-fx-font-size: 24px;" wrapText="true">Login</Label>

        <HBox alignment="CENTER" spacing="10.0">
            <Label>Username: </Label>
            <TextField fx:id="usernameField" />
        </HBox>

        <HBox alignment="CENTER" spacing="10.0">
            <Label>Password: </Label>
            <PasswordField fx:id="passwordField" />
        </HBox>

        <Button fx:id="loginButton" onAction="#onLogin" text="Login" />

        <Label fx:id="errorMessage" textFill="RED" wrapText="true" textAlignment="CENTER" />
    </VBox>

</AnchorPane>
