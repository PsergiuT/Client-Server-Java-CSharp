<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.AppController"
            prefHeight="600.0" prefWidth="900.0">

    <VBox alignment="CENTER" spacing="10.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
            <Label text="Meciuri" alignment="CENTER" style="-fx-font-weight: bold; -fx-padding: 0 0 5 0;" />
            <TableView fx:id="MeciuriTableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="tableColumnMeciId" text="ID" />
                    <TableColumn fx:id="tableColumnMeciDescriere" text="Descriere" />
                    <TableColumn fx:id="tableColumnMeciPret" text="Pret" />
                    <TableColumn fx:id="tableColumnMeciNrLocuri" text="Nr Locuri" />
                    <TableColumn fx:id="tableColumnMeciSoldOut" text="Sold Out" />
                </columns>
            </TableView>
        </VBox>
        <HBox>
            <VBox>
                <HBox alignment="CENTER" spacing="10.0">
                    <Label>Id bilet: </Label>
                    <TextField fx:id="idBiletField" />
                </HBox>
                <HBox alignment="CENTER" spacing="10.0">
                    <Label>Nume Client: </Label>
                    <TextField fx:id="numeClientField" />
                </HBox>
                <HBox alignment="CENTER" spacing="10.0">
                    <Label>Adresa Client: </Label>
                    <TextField fx:id="adresaClientField" />
                </HBox>
                <HBox alignment="CENTER" spacing="10.0">
                    <Label>Numar Locuri: </Label>
                    <TextField fx:id="numarLocuriField" />
                </HBox>
                <Label fx:id="errorMessage" textFill="RED" />
            </VBox>
            <Label>             </Label>
            <VBox>
                <Button fx:id="addBiletButton" onAction="#onAddBiletLogin" text="Adauga Bilet" />
                <Button fx:id="modificaButton" onAction="#onModifica" text="Modifica Bilet" />
                <Button fx:id="cautaButton" onAction="#onCauta" text="Cauta Meciuri" />
                <Button fx:id="resetButton" onAction="#onReset" text="Reset" />
            </VBox>
            <Button fx:id="logoutButton" onAction="#onLogout" text="Logout" />
        </HBox>
    </VBox>

</AnchorPane>
